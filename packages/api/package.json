{
  "name": "@vanischat/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "test": "vitest run",
    "build": "tsup src/index.ts --format esm --outDir dist",
    "dev": "bun run src/dev.ts",
    "dev:wrangler": "wrangler dev src/index.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "drizzle-orm": "^0.38.0",
    "@libsql/client": "^0.14.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "tsup": "^8.3.0",
    "drizzle-kit": "^0.30.0",
    "@types/node": "^22.0.0",
    "@types/bun": "^1.0.0"
  }
}
